# ============================================================
# AI-Powered Stock Analysis Dashboard — Environment Variables
# ============================================================
# Rename this file to .env and fill in your real API keys.
# NEVER commit the actual .env file to version control.

# --- Financial Modeling Prep (FMP) ---
# Get your key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# --- NewsAPI ---
# Get your key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# --- Anthropic Claude API ---
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
